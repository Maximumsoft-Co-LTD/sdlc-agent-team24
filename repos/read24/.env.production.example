# ============================================
# Production env (Cloud Run) — DO NOT COMMIT real values
# ============================================
# Secrets ที่ "ต้องใส่ผ่าน Secret Manager" (อย่า hardcode ใน Dockerfile)
#   read24-mongodb-uri        → MONGODB_URI
#   read24-jwt-secret         → JWT_SECRET
#   read24-refresh-secret     → REFRESH_TOKEN_SECRET
#   read24-gcs-access-key     → MINIO_ACCESS_KEY  (GCS HMAC access key)
#   read24-gcs-secret-key     → MINIO_SECRET_KEY  (GCS HMAC secret)

# --- MongoDB (Atlas) ---
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/read24?retryWrites=true&w=majority

# --- File storage: GCS (S3-compatible via HMAC) ---
# โค้ดใน src/lib/minio.ts ใช้ var ชื่อ MINIO_* แต่ชี้ไปที่ GCS
MINIO_ENDPOINT=storage.googleapis.com
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_BUCKET=read24-files
MINIO_ACCESS_KEY=<GCS HMAC access key>
MINIO_SECRET_KEY=<GCS HMAC secret key>

# --- Auth ---
JWT_SECRET=<openssl rand -hex 32>
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=<openssl rand -hex 32>

# --- App ---
NEXT_PUBLIC_APP_URL=https://read24-xxxxx-as.a.run.app
NODE_ENV=production
